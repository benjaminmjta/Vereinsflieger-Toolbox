{
  "manifest_version": 3,
  "name": "Vereinsflieger Toolbox",
  "version": "1.0",
  "browser_specific_settings": {
    "gecko": {
      "id": "vereinsflieger-toolbox@benmajta.dev",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "description": "Eine Toolbox für Vereinsflieger.de. Unterstützt momentan die Bordbuch-Buchhaltung mit einem Zeiten- und Landungsrechner.",
  "permissions": ["activeTab", "scripting"],
  "icons": {
    "48": "paper-plane-solid-full.svg",
    "128": "paper-plane-solid-full.svg"
  },
  "action": {
    "default_icon": "paper-plane-solid-full.svg",
    "default_popup": "toolbox.html",
    "default_title": "Vereinsflieger Toolbox öffnen"
  }
}
